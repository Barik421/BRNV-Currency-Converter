{
  "manifest_version": 3,
  "name": "BRNV Currency Converter",
  "short_name": "BRNV Converter",
  "description": "A simple and clean currency and crypto converter with quick access to BRNV Currency Converter.",
  "version": "1.1.2",
  "action": {
    "default_popup": "popup.html",
    "default_title": "BRNV Converter"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://open.er-api.com/*",
    "https://api.coingecko.com/*"
  ]
}
